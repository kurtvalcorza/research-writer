# Research PDFs (user's private files - don't commit)
corpus/*
!corpus/.gitkeep
*.pdf

# Generated outputs (regenerate each run)
# NOTE: pattern is outputs/* (not outputs/) so the negations below work —
# git does not descend into fully-ignored directories
outputs/*
!outputs/.gitkeep
!outputs/execution-log.example.json

# User-specific search strategy may contain unpublished research scope;
# commit it only deliberately
settings/search-strategy.md

# Temporary/backup files
*.tmp
*.bak
*.json.bak
*~

# IDE/Editor files
.vscode/
.idea/
*.swp
*.swo
*.iml
.claude/settings.local.json

# Python/Node cache
__pycache__/
node_modules/
*.pyc

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db
